{
  "name": "baseball-crawl",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/rocker-org/devcontainer-features/apt-packages:1": {
      "packages": "git,curl,jq"
    }
  },
  "postCreateCommand": "curl -fsSL https://claude.ai/install.sh | bash && npm i -g @openai/codex && pip install -r requirements.txt && ./scripts/install-hooks.sh && .devcontainer/post-create-env.sh",
  "customizations": {
    "vscode": {
      "settings": {
        // Per-port binding defaults for forwarded ports.
        "remote.portsAttributes": {
          "8000": {
            "localPortHost": "localhost"
          },
          "8001": {
            "localPortHost": "localhost"
          },
          "8180": {
            "localPortHost": "localhost"
          }
        }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.debugpy",
        "Anthropic.claude-code",
        "openai.chatgpt",
        "ReprEng.csv"
      ]
    }
  },
  "remoteUser": "vscode",
  // In Docker-in-Docker devcontainers, compose-published ports are reachable
  // in the devcontainer namespace. Host access requires VS Code forwarding.
  "forwardPorts": [8000, 8180],
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind"
  ],
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/bin"
  },
  "sshAgent": "local"
}

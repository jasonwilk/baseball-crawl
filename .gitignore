# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# pytest
.pytest_cache/

# Environment / credentials
.env
.env.*
!.env.example
secrets/

# IDE
.vscode/
.idea/

# Claude Code local settings (per-machine permissions)
.claude/settings.local.json

# Codex local runtime state
.codex-home/

# Project-local tool cache (gitignored binaries -- e.g. RTK for Codex lane)
.tools/

# Docker Compose local overrides (copy from .example)
docker-compose.override.yml

# OS
.DS_Store

# Data (local dev outputs)
# Ignore the runtime database and any other generated files under data/,
# but commit seed SQL files (data/seeds/ is source-controlled).
data/
!data/seeds/
!data/seeds/**

# Database backups (created by scripts/backup_db.py)
data/backups/


# Ephemeral data directory -- safe zone for raw API responses and scratch data
/ephemeral/*
!/ephemeral/README.md
!/ephemeral/scratch/
/ephemeral/scratch/*
!/ephemeral/scratch/.gitkeep

{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline.sh",
    "padding": 1
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pii-check.sh",
            "timeout": 10,
            "statusMessage": "Checking staged files for PII..."
          }
        ]
      }
    ]
  }
}

{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline.sh",
    "padding": 1
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pii-check.sh",
            "timeout": 10,
            "statusMessage": "Checking staged files for PII..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/epic-archive-check.sh",
            "timeout": 10,
            "statusMessage": "Checking for unarchived completed epics..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pytest-verbose.sh",
            "timeout": 5,
            "statusMessage": "Ensuring pytest verbose mode..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pytest-exitfirst-warn.sh",
            "timeout": 5,
            "statusMessage": "Checking for -x/--exitfirst..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking write path..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/worktree-guard.sh",
            "timeout": 5,
            "statusMessage": "Checking write path..."
          }
        ]
      }
    ]
  }
}

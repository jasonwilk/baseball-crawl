# baseball-crawl environment configuration
# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values, then:
#   docker compose up

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to the SQLite database file, relative to the app's working directory
# inside the container (/app). The ./data directory is host-mounted, so the
# file is visible on your filesystem at ./data/app.db.
# Required.
DATABASE_PATH=./data/app.db

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Runtime environment. Controls logging verbosity and debug features.
# Valid values: development | production
# Required.
APP_ENV=development

# Log level for the application. Standard Python logging levels.
# Valid values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Optional. Defaults to INFO.
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Cloudflare Tunnel + Zero Trust Access (E-009-04)
# ---------------------------------------------------------------------------

# Cloudflare Tunnel token for the cloudflared service in docker-compose.yml.
# Obtain from: Cloudflare Zero Trust dashboard -> Networks -> Tunnels
#   -> <your tunnel> -> Configure -> Docker command (copy the token value).
# Optional for local dev (cloudflared container not needed locally).
# Required in production.
# CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare Access service token for machine-to-machine API calls.
# These credentials allow Python crawlers to pass the Zero Trust Access
# check on api.baseball.<domain> without a human login flow.
# Obtain from: Cloudflare Zero Trust dashboard -> Access -> Service Tokens
#   -> Create Service Token. Store Client ID and Client Secret here.
# Optional for local dev; Required in production for crawler -> API calls.
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# GameChanger API credentials (managed by scripts/refresh_credentials.py)
# ---------------------------------------------------------------------------

# These values are written automatically by scripts/refresh_credentials.py.
# Do not set them manually. They have short lifespans and must be refreshed
# regularly from a real browser session.
# See scripts/refresh_credentials.py --help for instructions.
# GC_TOKEN=
# GC_COOKIE=

# ---------------------------------------------------------------------------
# Authentication (E-023)
# ---------------------------------------------------------------------------

# Dev bypass: set to an email address to skip the login page entirely.
# A user with is_admin=1 will be auto-created if the email is not in the DB.
# Leave unset in production.
# DEV_USER_EMAIL=dev@example.com

# Public base URL of the application. Used to construct magic link URLs.
# In dev: http://baseball.localhost:8001 (direct to app container, port 8001).
#   Port 8001 bypasses Traefik; port 8000 goes through Traefik (requires
#   Host: baseball.localhost). Both use the same hostname.
# In production: your public hostname (e.g. https://baseball.example.com).
# Optional. Defaults to http://baseball.localhost:8001.
# APP_URL=http://baseball.localhost:8001

# Mailgun API credentials for sending magic link emails.
# If MAILGUN_API_KEY is unset, magic links are logged to stdout (dev mode).
# Required in production.
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.example.com
# MAILGUN_FROM_EMAIL=noreply@mg.example.com

# First admin user email address. Used only as documentation -- the actual user
# must be seeded manually via SQLite before the admin page is accessible:
#   sqlite3 data/app.db "INSERT INTO users (email, display_name, is_admin) VALUES ('[your-email]', 'Jason', 1);"
# See src/api/templates/admin/users.html for the full bootstrap one-liner.
# Optional (informational only -- not read by the app).
# ADMIN_EMAIL=jason@example.com

# WebAuthn / passkey configuration (E-023-03)
# WEBAUTHN_RP_ID: The "relying party ID" for WebAuthn. Must match the hostname
#   where the app is served. Browsers enforce this strictly -- a passkey
#   registered on "baseball.localhost" will NOT work on "localhost".
# In dev: baseball.localhost (matches the hostname in the browser URL bar).
#   Browsers exempt *.localhost from HTTPS requirements.
# In production: your public hostname (e.g. baseball.example.com).
# Optional. Defaults to baseball.localhost.
# WEBAUTHN_RP_ID=baseball.localhost

# WEBAUTHN_ORIGIN: The full origin (scheme + host + port) used by the browser
#   when making WebAuthn requests. Must match what the browser sends in
#   clientDataJSON. Required for WebAuthn verification to succeed.
# In dev: http://baseball.localhost:8001 (must match APP_URL).
# In production: https://baseball.example.com (must be HTTPS).
# Optional. Defaults to http://baseball.localhost:8001.
# WEBAUTHN_ORIGIN=http://baseball.localhost:8001

# ---------------------------------------------------------------------------
# MCP Server Tokens (used by .mcp.json)
# ---------------------------------------------------------------------------

# Bright Data MCP token. Referenced in .mcp.json via ${BRIGHT_DATA_TOKEN}.
# Must also be exported in the shell environment for Claude Code to read it
# (Docker Compose reads .env, but Claude Code's .mcp.json reads shell env vars).
# The .bashrc auto-exports this token from .env into the shell.
# BRIGHT_DATA_TOKEN=

# ---------------------------------------------------------------------------
# Upstream Proxy (Bright Data)
# ---------------------------------------------------------------------------

# Master switch: set to "true" to route traffic through Bright Data proxies.
# When false or unset, all traffic goes direct (no proxy).
# Both Python crawlers and mitmproxy respect this setting.
# PROXY_ENABLED=false

# Residential proxy URL for web-profile sessions (Chrome browser fingerprint).
# Format: http://USERNAME:PASSWORD@brd.superproxy.io:33335
# Used by Python crawlers when profile="web" and by mitmproxy --profile web.
# PROXY_URL_WEB=

# Mobile proxy URL for mobile-profile sessions (iOS Odyssey app fingerprint).
# Format: http://USERNAME:PASSWORD@brd.superproxy.io:33335
# Used by Python crawlers when profile="mobile" and by mitmproxy --profile mobile.
# PROXY_URL_MOBILE=

# baseball-crawl environment configuration
# Copy this file to .env and fill in the values.
# .env is git-ignored and must never be committed.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values, then:
#   docker compose up
#
# Top-level sections:
#   1. CORE INFRASTRUCTURE   -- database, app runtime
#   2. GAMECHANGER API       -- connection, credentials, web/mobile profiles
#   3. WEB APPLICATION       -- dashboard auth, Cloudflare ingress
#   4. FEATURES & LLM        -- feature flags + OpenRouter Tier 2 enrichment
#   5. OPERATIONS & DEV      -- proxy, mitmproxy capture, MCP, devcontainer

# ============================================================================
# 1. CORE INFRASTRUCTURE
# ============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Path to the SQLite database file, relative to the app's working directory
# inside the container (/app). The ./data directory is host-mounted, so the
# file is visible on your filesystem at ./data/app.db.
# Required.
DATABASE_PATH=./data/app.db

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Runtime environment. Controls logging verbosity and debug features.
# Dev default: development. Production: production
# Valid values: development | production
# Required.
APP_ENV=development

# Log level for the application. Standard Python logging levels.
# Valid values: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Optional. Defaults to INFO.
LOG_LEVEL=INFO

# ============================================================================
# 2. GAMECHANGER API
# ============================================================================

# ---------------------------------------------------------------------------
# Connection
# ---------------------------------------------------------------------------

# Base API URL (same for both web and mobile profiles).
# Required.
GAMECHANGER_BASE_URL=https://api.team-manager.gc.com

# ---------------------------------------------------------------------------
# Account Credentials
# ---------------------------------------------------------------------------
#
# Email and password for the GameChanger account. Used for full programmatic
# login when refresh tokens expire (rare -- refresh tokens last 14 days).
# These are the same credentials you use to log into web.gc.com.
#
# Required for programmatic login. Not needed if you only do browser captures.
GAMECHANGER_USER_EMAIL=coach@example.com
GAMECHANGER_USER_PASSWORD=your-gamechanger-password

# ---------------------------------------------------------------------------
# Web Profile
# ---------------------------------------------------------------------------
#
# Web profile credentials for Chrome browser traffic.
# Used by GameChangerClient(profile="web").
#
# Token architecture (three tiers, most to least durable):
#   1. Client ID + Client Key -- static app secrets from the web.gc.com JS
#      bundle. Same for all users. Only change on GC app deploys (rare).
#   2. Refresh token -- 14-day JWT. Auto-renewed: each POST /auth refresh
#      call returns a fresh one. Initial capture from browser or programmatic
#      login with email+password.
#   3. Access token -- ~61-minute JWT. Obtained programmatically via refresh.
#      Never stored in .env -- generated on demand by the auth module.
#
# The system generates gc-signature headers programmatically using the client
# key + HMAC-SHA256, so no manual signature capture is needed.

# Client ID for the web app (from the JS bundle, same for all users).
GAMECHANGER_CLIENT_ID_WEB=00000000-0000-0000-0000-000000000000

# HMAC-SHA256 signing key (Base64). Extracted from web.gc.com JS bundle.
# Source: search the main bundle for "clientId:clientKey" colon-separated string.
GAMECHANGER_CLIENT_KEY_WEB=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Refresh token JWT (14-day lifetime). Obtained from browser capture or
# programmatic login. Each refresh call returns a replacement token.
# Optional when GAMECHANGER_USER_EMAIL + GAMECHANGER_USER_PASSWORD are set:
# bb creds refresh will run the full login flow and obtain a refresh token automatically.
GAMECHANGER_REFRESH_TOKEN_WEB=eyJ...your-refresh-token-jwt

# Device ID: stable 32-char hex string used in gc-device-id request headers.
# Auto-generated: if this key is absent when running bb creds refresh with
# email+password, a synthetic device ID is generated and written here automatically.
# GC does not enforce device ID binding (confirmed 2026-03-18).
GAMECHANGER_DEVICE_ID_WEB=0000000000000000000000000000000000

# App name for web profile (always "web").
GAMECHANGER_APP_NAME_WEB=web

# ---------------------------------------------------------------------------
# Mobile Profile
# ---------------------------------------------------------------------------
#
# Mobile profile credentials for iOS GameChanger app traffic.
# Used by GameChangerClient(profile="mobile").
# Captured via mitmproxy from iOS device traffic.
#
# Token architecture: same three-tier model as web (client ID/key, refresh
# token, access token). However, the mobile client ID is DIFFERENT from web
# (confirmed 2026-03-08: 0f18f027-c51e-4122-a330-9d537beb83e0). The mobile
# client key is almost certainly different too -- it is embedded in the iOS
# binary alongside the client ID (as "clientId:clientKey"). The mobile
# client key has NOT yet been extracted; binary analysis of the iOS app is
# required.
#
# Access token lifetime is ~12 hours on mobile (vs ~60 min on web).
# Refresh token lifetime is the same: 14 days.
#
# Until the mobile client key is extracted, programmatic token refresh for
# the mobile profile is not possible (gc-signature cannot be computed).

# Client ID for the iOS app. CONFIRMED DIFFERENT from web client ID.
# Value confirmed 2026-03-08 from live JWT decode via mitmweb.
GAMECHANGER_CLIENT_ID_MOBILE=0f18f027-c51e-4122-a330-9d537beb83e0

# HMAC-SHA256 signing key for the iOS app. NOT YET EXTRACTED.
# Embedded in the iOS binary as "clientId:clientKey" (same pattern as web).
# Do NOT use the web client key here -- the mobile client ID differs, so
# the key almost certainly also differs.
# GAMECHANGER_CLIENT_KEY_MOBILE=

# Refresh token JWT (14-day lifetime). Captured via mitmproxy response body
# capture (requires E-075-02 addon upgrade -- response handler not yet
# implemented). Leave commented out until captured.
# GAMECHANGER_REFRESH_TOKEN_MOBILE=

# Device ID from iOS app (uppercase UUID format).
GAMECHANGER_DEVICE_ID_MOBILE=00000000-0000-0000-0000-000000000000

# App name for mobile profile. UNRESOLVED INCONSISTENCY as of 2026-03-08:
# client.py says the iOS app "does not send gc-app-name at all";
# headers.md previously said "mobile" (inferred); the credential extractor
# should write the actual captured value here. Leave as "iOS" (the
# credential extractor default) until confirmed from a proxy capture.
GAMECHANGER_APP_NAME_MOBILE=iOS

# Manually-captured mobile access token (workaround until GAMECHANGER_CLIENT_KEY_MOBILE
# is extracted from the iOS binary). The mobile access token lasts ~12 hours.
# Capture from mitmweb: any authenticated API request -> gc-token request header.
# When GAMECHANGER_CLIENT_KEY_MOBILE is set, this field is ignored (programmatic
# refresh is used instead). Required only when CLIENT_KEY_MOBILE is absent.
# GAMECHANGER_ACCESS_TOKEN_MOBILE=eyJ...your-mobile-access-token-jwt

# ============================================================================
# 3. WEB APPLICATION
# ============================================================================

# ---------------------------------------------------------------------------
# Authentication (E-023) -- Dashboard Auth
# ---------------------------------------------------------------------------

# Dev bypass: set to an email address to skip the login page entirely.
# A user record will be found or created by email if not already in the DB.
# The bypass does NOT grant admin access -- admin still requires the email to
# match ADMIN_EMAIL or the user to have role='admin' in the database.
# Leave unset in production (app fails to start if APP_ENV=production is also set).
# DEV_USER_EMAIL=dev@example.com

# Public base URL of the application. Used to construct magic link URLs.
# In dev: http://baseball.localhost:8001 (direct to app container, port 8001).
#   Port 8001 bypasses Traefik; port 8000 goes through Traefik (requires
#   Host: baseball.localhost). Both use the same hostname.
# In production: https://bbstats.ai
# Optional. Defaults to http://baseball.localhost:8001.
# APP_URL=http://baseball.localhost:8001

# Mailgun API credentials for sending magic link emails.
# If MAILGUN_API_KEY is unset, magic links are logged to stdout (dev mode).
# Required in production.
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=mg.bbstats.ai
# MAILGUN_FROM_EMAIL=noreply@mg.bbstats.ai

# Bootstrap/fallback admin email. Read by _require_admin(): if set, any
# authenticated user whose email matches this value is granted admin access
# regardless of their database role. The primary long-term path is to set
# role='admin' directly in the database:
#   sqlite3 data/app.db "UPDATE users SET role='admin' WHERE email='you@example.com';"
# ADMIN_EMAIL=coach@example.com

# WebAuthn / passkey configuration (E-023-03)
# WEBAUTHN_RP_ID: Must match the hostname where the app is served.
# Dev default: baseball.localhost. Production: bbstats.ai
# Optional. Defaults to baseball.localhost.
# WEBAUTHN_RP_ID=bbstats.ai

# WEBAUTHN_ORIGIN: Full origin (scheme + host + port) for WebAuthn requests.
# Must match APP_URL. Must be HTTPS in production.
# Dev default: http://baseball.localhost:8001. Production: https://bbstats.ai
# Optional. Defaults to http://baseball.localhost:8001.
# WEBAUTHN_ORIGIN=https://bbstats.ai

# ---------------------------------------------------------------------------
# Cloudflare Tunnel + Access
# ---------------------------------------------------------------------------

# Cloudflare Tunnel token for the cloudflared service in docker-compose.yml.
# Obtain from Cloudflare Zero Trust dashboard -> Networks -> Tunnels (bbstats-ai).
# Optional for local dev. Required in production.
# CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare Access service token for machine-to-machine API calls that must
# pass through Cloudflare Access policies. OPTIONAL -- only needed if CF Access
# is actively enforcing auth on the tunnel. For bbstats.ai, CF Access policies
# must be REMOVED before go-live (the app handles auth internally via magic
# links and passkeys). Do not set these unless you have re-enabled CF Access.
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=

# Cloudflare API token for programmatic Cloudflare API management (DNS records,
# Access policy management, etc.). Scoped to the bbstats.ai zone only.
# This is NOT the tunnel token (CLOUDFLARE_TUNNEL_TOKEN) and is NOT used by the
# Cloudflare MCP server in .mcp.json (which authenticates via OAuth browser popup).
# Only required for scripts that call the Cloudflare API directly.
# CLOUDFLARE_API_TOKEN=

# ============================================================================
# 4. FEATURES & LLM INTEGRATIONS
# ============================================================================

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------

# Enable the predicted starter section in reports and dashboard (E-212).
# Values: 1, true, yes (case-insensitive) to enable; anything else to disable.
# Default: disabled (absent).
FEATURE_PREDICTED_STARTER=1

# Enable the Game Plan matchup analysis section in standalone scouting reports
# (E-228). When enabled, the report generation form exposes an "Include matchup
# analysis" checkbox and an LSB-team selector. Requires OPENROUTER_API_KEY for
# the Tier 2 LLM enrichment; without the key, the section falls back to the
# deterministic engine output.
# Values: 1, true, yes (case-insensitive) to enable; anything else to disable.
# Default: disabled (absent).
FEATURE_MATCHUP_ANALYSIS=1

# Strict hallucination guardrail for matchup LLM output. When enabled, any
# player_id round-trip mismatch between the LLM response and the deterministic
# inputs raises an error and aborts the matchup section. When disabled
# (default), mismatches are logged and the section degrades gracefully.
# Values: 1, true, yes (case-insensitive) to enable; anything else to disable.
# Default: disabled (absent).
# FEATURE_MATCHUP_STRICT=1

# ---------------------------------------------------------------------------
# OpenRouter LLM (Tier 2 enrichment for E-212 predicted starter and E-228 matchup)
# ---------------------------------------------------------------------------

# API key for OpenRouter. Required for Tier 2 LLM-enhanced sections in
# standalone reports. When absent, reports use Tier 1 (deterministic) only.
# Obtain from https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...

# Model to use for LLM analysis. Optional.
# Default: anthropic/claude-haiku-4-5-20251001
# OPENROUTER_MODEL=anthropic/claude-haiku-4-5-20251001

# ============================================================================
# 5. OPERATIONS & DEV TOOLS
# ============================================================================

# ---------------------------------------------------------------------------
# Upstream Proxy (Bright Data)
# ---------------------------------------------------------------------------

# Master switch: set to "true" to route traffic through Bright Data proxies.
# When false or unset, all traffic goes direct (no proxy).
PROXY_ENABLED=false

# Residential proxy URL for web-profile sessions.
# Format: http://USERNAME:PASSWORD@brd.superproxy.io:33335
# PROXY_URL_WEB=

# Mobile proxy URL for mobile-profile sessions.
# Format: http://USERNAME:PASSWORD@brd.superproxy.io:33335
# PROXY_URL_MOBILE=

# ---------------------------------------------------------------------------
# Proxy Capture (mitmproxy endpoint logger)
# ---------------------------------------------------------------------------

# Master switch for full payload capture in the mitmproxy endpoint logger.
# When true (default), JSONL entries include request/response bodies, headers,
# and full query parameters. When false, metadata-only mode (backward compatible).
PROXY_CAPTURE_BODIES=true

# When true, sensitive headers (gc-token, gc-device-id, authorization,
# gc-signature, cookie, set-cookie) are stripped from captured headers.
# When false (default), all headers are captured unfiltered.
# The session store is gitignored and secured, so the default is no filtering.
PROXY_STRIP_AUTH_HEADERS=false

# Maximum body size (bytes) before truncation. Bodies exceeding this are
# replaced with a sentinel string "<truncated: N bytes>".
# Default: 2097152 (2 MB).
# MAX_BODY_BYTES=2097152

# ---------------------------------------------------------------------------
# MCP Server Tokens (used by .mcp.json)
# ---------------------------------------------------------------------------

# Bright Data MCP token. Referenced in .mcp.json via ${BRIGHT_DATA_TOKEN}.
# BRIGHT_DATA_TOKEN=

# ---------------------------------------------------------------------------
# Codex Sandbox (devcontainer compatibility)
# ---------------------------------------------------------------------------

# Set to 1 to disable bubblewrap sandboxing for codex exec in scripts.
# Required on Ubuntu 24.04 devcontainers (AppArmor restricts unprivileged
# user namespaces). Not needed on Mac (Docker Desktop VM has no restriction).
# CODEX_SANDBOX_OFF=1

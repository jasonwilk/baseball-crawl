# Direct runtime dependencies for baseball-crawl.
# requirements.txt is GENERATED by pip-compile -- do not edit it directly.
# To regenerate: pip-compile requirements.in -o requirements.txt --strip-extras --generate-hashes

httpx~=0.28          # HTTP client for GameChanger crawlers
fastapi~=0.115       # API framework (FastAPI)
uvicorn[standard]~=0.34  # ASGI server for FastAPI
starlette~=0.41      # Pinned explicitly -- FastAPI transitive; we import run_in_threadpool directly
jinja2~=3.1          # HTML templating for server-rendered pages
aiofiles~=24.1       # Async file I/O for static file serving
python-multipart~=0.0.20  # Form parsing (required for FastAPI Form() parameters)
webauthn~=2.2        # WebAuthn / passkey support
python-dotenv~=1.0   # Environment variable loading from .env files
pyyaml~=6.0          # YAML config parsing (teams.yaml)
typer[all]>=0.9      # CLI framework for operator commands (rich + shellingham extras)
